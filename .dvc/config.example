# DVC Configuration Examples
# ===========================
# Copy this to config.local for your own remote settings
# (config.local is gitignored and overrides config)

# Public GitHub Raw mirror (default checked-in pull remote)
# ---------------------------------------------------------
# [core]
#     remote = githubraw
# ['remote "githubraw"']
#     url = https://raw.githubusercontent.com/<owner>/<repo>/dvc-storage/.dvc/cache
#
# The checked-in default remote is intended for portable read-only pulls.
# Configure your own writable remote locally in `.dvc/config.local` when you
# need to publish new cache objects.

# Local Storage (example writable override)
# -----------------------------------------
# [core]
#     remote = localremote
# ['remote "localremote"']
#     url = /path/to/local/storage

# AWS S3 (recommended for production)
# ------------------------------------
# [core]
#     remote = s3remote
# ['remote "s3remote"']
#     url = s3://your-bucket-name/dvc-storage
#     # Optional: specify profile for credentials
#     # profile = your-aws-profile

# Google Cloud Storage
# ----------------------
# [core]
#     remote = gcsremote
# ['remote "gcsremote"']
#     url = gs://your-bucket-name/dvc-storage
#     # GCS uses application default credentials

# Azure Blob Storage
# --------------------
# [core]
#     remote = azureremote
# ['remote "azureremote"']
#     url = azure://your-container-name/dvc-storage
#     # Requires AZURE_STORAGE_CONNECTION_STRING env var

# SSH/SFTP Remote
# ----------------
# [core]
#     remote = sshremote
# ['remote "sshremote"']
#     url = ssh://user@host/path/to/storage

# Notes:
# - The repo's default checked-in remote should remain a portable read-only pull mirror.
# - Put writable remote overrides in `.dvc/config.local` so teammates are not forced onto a machine-local path.
# - Use `dvc remote modify <remote> --local credentialpath <path>` for sensitive settings
# - Cloud remotes require additional DVC packages: pip install dvc-s3, dvc-gs, dvc-azure
